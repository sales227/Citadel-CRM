# Google Apps Script Backend
# Replace with your actual Apps Script Web App URL from Deploy → New Deployment
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Mock mode — set to 'true' for local development without a backend
# When false or absent, VITE_APPS_SCRIPT_URL must be configured
VITE_USE_MOCK=false

# Company logo (fallback: /logo.jpg)
VITE_LOGO_URL=/logo.jpg
